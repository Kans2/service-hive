# Environment Variables — Smart Leads Backend

# Server
PORT=8000

# MongoDB Connection
# Local: mongodb://localhost:27017/smart-leads
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/smart-leads
MONGODB_URI=mongodb://localhost:27017/smart-leads

# JWT — CHANGE THIS TO A LONG RANDOM STRING IN PRODUCTION
JWT_SECRET=your_super_secret_jwt_key_change_in_production_minimum_32_chars
JWT_EXPIRES_IN=7d

# Environment
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
